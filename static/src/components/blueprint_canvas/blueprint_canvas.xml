<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pest_control.BlueprintCanvas" owl="1">
        <div class="o_blueprint_canvas_widget">
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center h-100 p-5">
                    <i class="fa fa-spinner fa-spin fa-3x" aria-hidden="true"/>
                </div>
            </t>
            <t t-elif="state.error">
                <div class="alert alert-danger m-2">
                    <i class="fa fa-exclamation-triangle me-2" aria-hidden="true"/>
                    <span t-esc="state.error.message || state.error" />
                </div>
            </t>
            <t t-else="">
                <div class="o_blueprint_zoom_bar">
                    <button class="btn btn-sm btn-light" t-on-click="onZoomIn" title="Zoom In">
                        <i class="fa fa-plus"/>
                    </button>
                    <span class="zoom-level" t-esc="Math.round(state.zoomLevel * 100) + '%'"/>
                    <button class="btn btn-sm btn-light" t-on-click="onZoomOut" title="Zoom Out">
                        <i class="fa fa-minus"/>
                    </button>
                    <button class="btn btn-sm btn-light" t-on-click="onZoomReset" title="Reset Zoom">
                        <i class="fa fa-compress"/>
                    </button>
                </div>
                <div class="o_blueprint_canvas_scroll" t-on-wheel="onWheel">
                    <div class="o_blueprint_canvas_inner" t-att-style="'transform: scale(' + state.zoomLevel + '); transform-origin: top left;'">
                        <div t-ref="container" 
                             class="blueprint-container" 
                             t-on-dragover.stop.prevent="onDragOver" 
                             t-on-drop.stop.prevent="onDrop"
                             t-on-click="onContainerClick"
                             tabindex="0"
                             role="application"
                             aria-label="Plano Interactivo de Trampas"
                             t-on-keydown="onKeyDown"
                             t-att-class="{'can-edit': state.data.can_edit and !props.readonly}">
                            
                            <img t-att-src="state.data.image_url" class="blueprint-image" draggable="false" alt="Plano de planta"/>
                            
                            <t t-foreach="state.data.traps" t-as="trap" t-key="trap.id">
                                <div class="blueprint-trap-marker"
                                     role="button"
                                     tabindex="0"
                                     t-att-aria-label="'Trampa ' + trap.name + ' - Estado: ' + trap.current_state"
                                     t-att-class="'state-' + trap.current_state + (state.selectedTrapId === trap.id ? ' selected' : '')"
                                     t-att-style="'left: ' + trap.coord_x_pct + '%; top: ' + trap.coord_y_pct + '%;'"
                                     t-att-draggable="state.data.can_edit and !props.readonly ? 'true' : 'false'"
                                     t-on-dragstart="(ev) => this.onDragStart(ev, trap)"
                                     t-on-dragend="onDragEnd"
                                     t-on-click="(ev) => this.onTrapMarkerClick(ev, trap)">
                                     
                                     <i class="fa fa-crosshairs" aria-hidden="true"/>
                                     
                                     <!-- Click-based popover -->
                                     <div class="o_blueprint_popover" t-if="state.selectedTrapId === trap.id" t-on-click.stop="">
                                         <div class="popover-header">
                                             <t t-esc="trap.name"/>
                                         </div>
                                         <div class="popover-info">
                                             <t t-esc="trap.trap_type_name"/>
                                         </div>
                                         <div class="mb-2">
                                             <span class="badge" t-att-class="
                                                 trap.current_state === 'funciona' ? 'text-bg-success' : 
                                                 trap.current_state === 'en_reparacion' ? 'text-bg-warning' : 
                                                 trap.current_state === 'no_funciona' ? 'text-bg-danger' : 'text-bg-secondary'
                                             "><t t-esc="trap.current_state"/></span>
                                         </div>
                                         <t t-if="state.data.can_edit">
                                             <div class="popover-actions">
                                                 <button class="btn btn-sm btn-outline-info"
                                                         t-on-click.stop="() => this.onEditTrap(trap)">
                                                     <i class="fa fa-pencil"/> Editar
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-primary"
                                                         t-on-click.stop="() => this.onRegisterIncident(trap)">
                                                     Registrar Incidencia
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-secondary"
                                                         t-on-click.stop="() => this.onViewHistory(trap)">
                                                     Historial
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-danger"
                                                         t-on-click.stop="() => this.onDeactivateTrap(trap.id)">
                                                     <i class="fa fa-archive"/> Desactivar
                                                 </button>
                                             </div>
                                         </t>
                                     </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
