<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pest_control.BlueprintCanvas" owl="1">
        <div class="o_blueprint_canvas_widget">
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center h-100 p-5">
                    <i class="fa fa-spinner fa-spin fa-3x" aria-hidden="true"/>
                </div>
            </t>
            <t t-elif="state.error">
                <div class="alert alert-danger m-2">
                    <i class="fa fa-exclamation-triangle me-2" aria-hidden="true"/>
                    <span t-esc="state.error.message || state.error" />
                </div>
            </t>
            <t t-else="">
                <div class="o_blueprint_zoom_bar">
                    <button class="btn btn-sm btn-light" t-on-click="onZoomIn" title="Zoom In">
                        <i class="fa fa-plus"/>
                    </button>
                    <span class="zoom-level" t-esc="Math.round(state.zoomLevel * 100) + '%'"/>
                    <button class="btn btn-sm btn-light" t-on-click="onZoomOut" title="Zoom Out">
                        <i class="fa fa-minus"/>
                    </button>
                    <button class="btn btn-sm btn-light" t-on-click="onZoomReset" title="Reset Zoom">
                        <i class="fa fa-compress"/>
                    </button>
                    <button class="btn btn-sm btn-light ms-2" t-on-click="toggleSidePanel" title="Lista de Trampas">
                        <i class="fa fa-list"/>
                    </button>
                    <button class="btn btn-sm" 
                            t-att-class="state.showIncidentBadges ? 'btn-warning' : 'btn-light'"
                            t-on-click="toggleIncidentBadges" 
                            title="Mostrar/Ocultar incidencias">
                        <i class="fa fa-bug"/>
                    </button>
                    <button class="btn btn-sm" 
                            t-att-class="state.heatmapActive ? 'btn-danger' : 'btn-light'"
                            t-on-click="toggleHeatmap" 
                            title="Mapa de Calor"
                            t-att-disabled="state.heatmapLoading">
                        <i t-att-class="state.heatmapLoading ? 'fa fa-spinner fa-spin' : 'fa fa-fire'"/>
                    </button>
                    <span class="mx-1 border-start" style="height: 20px;"/>
                    <button class="btn btn-sm" 
                            t-att-class="state.isEditMode ? 'btn-success' : 'btn-light'"
                            t-on-click="toggleEditMode" 
                            title="Modo Edición"
                            t-if="state.data.can_edit">
                        <i t-att-class="state.isEditMode ? 'fa fa-unlock' : 'fa fa-lock'"/>
                    </button>
                    <button class="btn btn-sm" 
                            t-att-class="state.drawingMode ? 'btn-primary' : 'btn-light'"
                            t-on-click="toggleDrawingMode" 
                            title="Dibujar Zona"
                            t-if="state.data.can_edit">
                        <i class="fa fa-pencil-square-o"/>
                    </button>
                    <t t-if="state.drawingMode">
                        <button class="btn btn-sm btn-success" t-on-click="finishDrawingZone" 
                                title="Cerrar Zona"
                                t-att-disabled="state.drawingPoints.length &lt; 3">
                            <i class="fa fa-check"/>
                        </button>
                        <button class="btn btn-sm btn-secondary" t-on-click="cancelDrawing" title="Cancelar">
                            <i class="fa fa-times"/>
                        </button>
                    </t>
                     <button class="btn btn-sm btn-outline-danger" 
                             t-if="state.selectedZoneId and state.data.can_edit"
                             t-on-click="deleteSelectedZone" 
                             title="Eliminar Zona">
                         <i class="fa fa-trash"/>
                     </button>
                     <span class="text-muted small ms-2" title="Tab: navegar trampas, Enter: abrir menu, Flechas: mover (en modo edicion), Esc: cerrar">
                         <i class="fa fa-keyboard-o"/>
                     </span>
                 </div>
                <div class="o_blueprint_canvas_scroll" t-on-wheel="onWheel">
                    <div class="o_blueprint_canvas_inner" t-att-style="'transform: scale(' + state.zoomLevel + '); transform-origin: top left;'">
                        <div t-ref="container" 
                             class="blueprint-container" 
                             t-on-dragover.stop.prevent="onDragOver" 
                             t-on-drop.stop.prevent="onDrop"
                             t-on-click="onContainerClick"
                             tabindex="0"
                             role="application"
                             aria-label="Plano Interactivo de Trampas"
                             t-on-keydown="onKeyDown"
                             t-att-class="{'can-edit': state.isEditMode and state.data.can_edit and !props.readonly, 'drawing-mode': state.drawingMode}">
                            
                            <img t-att-src="state.data.image_url" class="blueprint-image" draggable="false" 
                                 t-att-alt="'Plano interactivo: ' + (props.record.data.name || 'Sin nombre')"/>

                            <div class="text-muted text-center p-2 small position-absolute" 
                                 style="bottom: 4px; left: 50%; transform: translateX(-50%); z-index: 2; pointer-events: none;"
                                 t-if="state.data and (!state.data.zones || !state.data.zones.length) and state.data.can_edit">
                                <i class="fa fa-info-circle"/> Sin zonas definidas. Use ✏️ para dibujar zonas.
                            </div>

                            <!-- SVG Zone Overlay -->
                            <svg class="o_zone_svg_overlay" viewBox="0 0 100 100" preserveAspectRatio="none"
                                 xmlns="http://www.w3.org/2000/svg">
                                <!-- Existing zones -->
                                <t t-foreach="state.data.zones || []" t-as="zone" t-key="zone.id">
                                    <polygon t-att-points="getZonePolygonPoints(zone)"
                                             t-att-fill="zone.color"
                                             t-att-stroke="state.selectedZoneId === zone.id ? '#0d6efd' : (zone.color || '#3498db')"
                                             t-att-stroke-width="state.selectedZoneId === zone.id ? '0.5' : '0.2'"
                                             style="cursor: pointer;"
                                             t-on-click="(ev) => this.onZoneClick(ev, zone)"/>
                                    <text t-att-x="getZoneCentroid(zone).x" t-att-y="getZoneCentroid(zone).y"
                                          text-anchor="middle" dominant-baseline="middle"
                                          font-size="2.5" fill="#333" font-weight="bold"
                                          style="pointer-events: none;">
                                        <t t-esc="zone.name"/>
                                    </text>
                                </t>
                                <!-- Drawing in progress -->
                                <t t-if="state.drawingMode and state.drawingPoints.length > 0">
                                    <polyline t-att-points="state.drawingPoints.map(p => p.x + ',' + p.y).join(' ')"
                                              fill="none" stroke="#0d6efd" stroke-width="0.3" stroke-dasharray="1,0.5"/>
                                    <t t-foreach="state.drawingPoints" t-as="pt" t-key="pt_index">
                                        <circle t-att-cx="pt.x" t-att-cy="pt.y" r="0.8" fill="#0d6efd"/>
                                    </t>
                                </t>
                            </svg>

                            <t t-foreach="state.data.traps" t-as="trap" t-key="trap.id">
                                <div t-if="isTrapVisible(trap)"
                                     role="button"
                                     tabindex="0"
                                     t-att-aria-label="'Trampa ' + trap.name + ', tipo ' + (trap.trap_type_name || 'sin tipo') + ', estado ' + trap.current_state"
                                     t-att-class="'blueprint-trap-marker state-' + trap.current_state + (state.selectedTrapId === trap.id ? ' selected' : '') + (isTrapHighlighted(trap) ? ' highlighted' : '')"
                                     t-att-style="'left: ' + trap.coord_x_pct + '%; top: ' + trap.coord_y_pct + '%;'"
                                     t-att-draggable="state.isEditMode and state.data.can_edit and !props.readonly ? 'true' : 'false'"
                                     t-on-dragstart="(ev) => this.onDragStart(ev, trap)"
                                     t-on-dragend="onDragEnd"
                                     t-on-click="(ev) => this.onTrapMarkerClick(ev, trap)">
                                     
                                     <i t-att-class="'fa ' + (trap.trap_type_icon || 'fa-crosshairs')" aria-hidden="true"/>
                                     <span class="o_incident_badge" 
                                           t-if="state.showIncidentBadges and trap.incident_count > 0"
                                           t-att-class="trap.incident_count > 5 ? 'badge-danger' : 'badge-warning'"
                                           t-esc="trap.incident_count"/>
                                     
                                      <!-- Click-based popover -->
                                     <div t-att-class="'o_blueprint_popover popover-' + this.getPopoverPosition(trap)" t-if="state.selectedTrapId === trap.id" t-on-click.stop=""
                                          role="dialog" t-att-aria-label="'Menu de trampa ' + trap.name">
                                         <div class="popover-header">
                                             <t t-esc="trap.name"/>
                                         </div>
                                         <div class="popover-info">
                                             <t t-esc="trap.trap_type_name"/>
                                         </div>
                                         <div class="mb-2">
                                             <span class="badge" t-att-class="
                                                 trap.current_state === 'funciona' ? 'text-bg-success' : 
                                                 trap.current_state === 'en_reparacion' ? 'text-bg-warning' : 
                                                 trap.current_state === 'no_funciona' ? 'text-bg-danger' : 'text-bg-secondary'
                                             "><t t-esc="trap.current_state"/></span>
                                         </div>
                                         <t t-if="state.data.can_edit">
                                             <div class="popover-actions">
                                                 <button class="btn btn-sm btn-outline-info"
                                                         t-on-click.stop="() => this.onEditTrap(trap)">
                                                     <i class="fa fa-pencil"/> Editar
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-primary"
                                                         t-on-click.stop="() => this.onRegisterIncident(trap)">
                                                     Registrar Incidencia
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-secondary"
                                                         t-on-click.stop="() => this.onViewHistory(trap)">
                                                     Historial
                                                 </button>
                                                 <button class="btn btn-sm btn-outline-danger"
                                                         t-on-click.stop="() => this.onDeactivateTrap(trap.id)">
                                                     <i class="fa fa-archive"/> Desactivar
                                                 </button>
                                             </div>
                                         </t>
                                     </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
                <div class="o_trap_detail_panel" t-if="state.trapDetail">
                    <div class="detail-header d-flex align-items-center justify-content-between">
                        <div>
                            <strong t-esc="state.trapDetail.trap_name"/> 
                            <span class="text-muted">— <t t-esc="state.trapDetail.trap_type"/></span>
                            <span class="badge ms-2" t-att-class="{
                                'text-bg-success': state.trapDetail.current_state === 'funciona',
                                'text-bg-warning': state.trapDetail.current_state === 'en_reparacion',
                                'text-bg-danger': state.trapDetail.current_state === 'no_funciona',
                                'text-bg-secondary': state.trapDetail.current_state === 'sin_registro' or !state.trapDetail.current_state
                            }" t-esc="state.trapDetail.current_state"/>
                            <small class="text-muted ms-2" t-if="state.trapDetail.location" t-esc="'📍 ' + state.trapDetail.location"/>
                        </div>
                        <button class="btn-close btn-sm" t-on-click="closeDetailPanel"/>
                    </div>
                    <div class="detail-tables">
                        <div class="detail-table-section">
                            <h6>Últimas Incidencias</h6>
                            <table class="table table-sm table-bordered mb-0">
                                <thead><tr><th>Fecha</th><th>Plaga</th><th>Tipo</th><th>Cant.</th></tr></thead>
                                <tbody>
                                    <t t-foreach="state.trapDetail.incidents" t-as="inc" t-key="inc_index">
                                        <tr>
                                            <td t-esc="inc.date"/>
                                            <td t-esc="inc.plague"/>
                                            <td t-esc="inc.type"/>
                                            <td t-esc="inc.count"/>
                                        </tr>
                                    </t>
                                    <tr t-if="!state.trapDetail.incidents.length">
                                        <td colspan="4" class="text-muted text-center">Sin incidencias</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="detail-table-section">
                            <h6>Historial de Estado</h6>
                            <table class="table table-sm table-bordered mb-0">
                                <thead><tr><th>Fecha</th><th>Estado</th><th>Usuario</th></tr></thead>
                                <tbody>
                                    <t t-foreach="state.trapDetail.states" t-as="st" t-key="st_index">
                                        <tr>
                                            <td t-esc="st.date"/>
                                            <td t-esc="st.state"/>
                                            <td t-esc="st.user"/>
                                        </tr>
                                    </t>
                                    <tr t-if="!state.trapDetail.states.length">
                                        <td colspan="3" class="text-muted text-center">Sin registros</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="o_blueprint_legend" t-if="state.data.trap_types and state.data.trap_types.length">
                    <div class="legend-header">Tipos de Trampa</div>
                    <div class="legend-list">
                        <t t-foreach="state.data.trap_types" t-as="tt" t-key="tt.id">
                            <div class="legend-item" 
                                 t-on-click="() => this.toggleTypeVisibility(tt.id)"
                                 t-att-class="{'legend-hidden': state.hiddenTypes.includes(tt.id)}">
                                <span class="legend-icon"><i t-att-class="'fa ' + (tt.icon || 'fa-crosshairs')"/></span>
                                <span class="legend-name" t-esc="tt.name"/>
                                <span class="badge text-bg-secondary" t-esc="tt.count"/>
                            </div>
                        </t>
                    </div>
                </div>
                <div class="o_blueprint_side_panel" t-if="state.sidePanelOpen">
                    <div class="side-panel-header">
                        <h6>Trampas <span class="badge text-bg-secondary" t-esc="state.data.traps.length"/></h6>
                        <input type="text" class="form-control form-control-sm mb-2" 
                               placeholder="Buscar trampa..."
                               t-on-input="onSearchTrap"
                               t-att-value="state.searchTerm"/>
                        <select class="form-select form-select-sm mb-2" t-on-change="onFilterTrapType">
                            <option value="">Todos los tipos</option>
                            <t t-foreach="uniqueTrapTypes" t-as="tt" t-key="tt.id">
                                <option t-att-value="tt.id" t-esc="tt.name"/>
                            </t>
                        </select>
                        <select class="form-select form-select-sm mb-2" t-on-change="onFilterTrapState">
                            <option value="">Todos los estados</option>
                            <option value="funciona">&#x2705; Funciona</option>
                            <option value="en_reparacion">&#x1F527; En Reparación</option>
                            <option value="no_funciona">&#x274C; No Funciona</option>
                            <option value="sin_registro">&#x26AA; Sin Registro</option>
                        </select>
                    </div>
                    <div class="side-panel-list">
                        <t t-foreach="filteredTraps" t-as="trap" t-key="trap.id">
                            <div class="side-panel-item" 
                                 t-on-click="() => this.onSidePanelTrapClick(trap.id)"
                                 t-att-class="{'active': state.highlightedTrapId === trap.id}">
                                <div class="d-flex align-items-center justify-content-between">
                                    <span class="fw-semibold text-truncate" t-esc="trap.name"/>
                                    <span class="badge ms-1" t-att-class="
                                        trap.current_state === 'funciona' ? 'text-bg-success' : 
                                        trap.current_state === 'en_reparacion' ? 'text-bg-warning' : 
                                        trap.current_state === 'no_funciona' ? 'text-bg-danger' : 'text-bg-secondary'
                                    ">
                                        <t t-esc="trap.current_state"/>
                                    </span>
                                </div>
                                <small class="text-muted" t-esc="trap.trap_type_name"/>
                            </div>
                        </t>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
