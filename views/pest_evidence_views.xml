<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.evidence – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_evidence_view_list" model="ir.ui.view">
        <field name="name">pest.evidence.list</field>
        <field name="model">pest.evidence</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="blueprint_id"/>
                <field name="location"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pendiente'"
                       decoration-success="state == 'resuelta'"/>
                <field name="supervisor_approval"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.evidence – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_evidence_view_form" model="ir.ui.view">
        <field name="name">pest.evidence.form</field>
        <field name="model">pest.evidence</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_resolve"
                            type="object"
                            string="Resolver"
                            class="btn-primary"
                            invisible="state != 'pendiente'"/>
                    <button name="action_approve"
                            type="object"
                            string="Visto Bueno"
                            class="btn-primary"
                            invisible="state != 'resuelta'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pendiente,resuelta"/>
                </header>
                <sheet>
                    <!-- Side-by-side images -->
                    <group>
                        <group string="Foto de Evidencia">
                            <field name="image_evidence" widget="image"
                                   options="{'size': [500, 400]}"/>
                        </group>
                        <group string="Foto de Resolución">
                            <field name="image_resolved" widget="image"
                                   options="{'size': [500, 400]}"/>
                        </group>
                    </group>

                    <group>
                        <group string="Información">
                            <field name="blueprint_id"/>
                            <field name="location"/>
                            <field name="description"/>
                        </group>
                        <group string="Fechas y Aprobación">
                            <field name="date"/>
                            <field name="resolution_date"/>
                            <field name="supervisor_approval"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.evidence – Kanban View (grouped by state)
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_evidence_view_kanban" model="ir.ui.view">
        <field name="name">pest.evidence.kanban</field>
        <field name="model">pest.evidence</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="blueprint_id"/>
                <field name="location"/>
                <field name="date"/>
                <field name="state"/>
                <field name="supervisor_approval"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong>
                                        <field name="location"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="blueprint_id"/></div>
                                <div>
                                    <i class="fa fa-calendar"/> <field name="date"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span t-if="record.supervisor_approval.raw_value"
                                          class="badge text-bg-success">
                                        <i class="fa fa-check"/> Aprobado
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.evidence – Action
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_evidence_action" model="ir.actions.act_window">
        <field name="name">Evidencias</field>
        <field name="res_model">pest.evidence</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registrar una nueva evidencia fotográfica
            </p>
            <p>Documente evidencias y su resolución con fotografías.</p>
        </field>
    </record>

</odoo>
