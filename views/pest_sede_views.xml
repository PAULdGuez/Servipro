<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.sede – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_sede_view_list" model="ir.ui.view">
        <field name="name">pest.sede.list</field>
        <field name="model">pest.sede</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="trap_count"/>
                <field name="blueprint_count"/>
                <field name="incident_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-info="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.sede – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_sede_view_form" model="ir.ui.view">
        <field name="name">pest.sede.form</field>
        <field name="model">pest.sede</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,inactive"/>
                </header>
                <sheet>
                    <!-- Stat Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_traps"
                                type="object"
                                class="oe_stat_button"
                                style="background-color: #bef202;"
                                icon="fa-crosshairs">
                            <field name="trap_count"
                                   string="Trampas"
                                   widget="statinfo"/>
                        </button>
                        <button name="action_view_blueprints"
                                type="object"
                                class="oe_stat_button"
                                style="background-color: #bef202;"
                                icon="fa-map">
                            <field name="blueprint_count"
                                   string="Planos"
                                   widget="statinfo"/>
                        </button>
                        <button name="action_view_incidents"
                                type="object"
                                class="oe_stat_button"
                                style="background-color: #bef202;"
                                icon="fa-bug">
                            <field name="incident_count"
                                   string="Incidencias"
                                   widget="statinfo"/>
                        </button>
                    </div>

                    <group>
                        <group string="Información General">
                            <field name="name"/>
                            <field name="street"/>
                            <field name="city"/>
                            <field name="country_id"/>
                        </group>
                        <group string="Estado">
                            <field name="state"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Planos" name="blueprints">
                            <field name="blueprint_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="trap_count"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Trampas" name="traps">
                            <field name="trap_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="trap_type_id"/>
                                    <field name="blueprint_id"/>
                                    <field name="location"/>
                                    <field name="current_state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Incidencias" name="incidents">
                            <field name="incident_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="trap_id"/>
                                    <field name="plague_type_id"/>
                                    <field name="incident_type" widget="badge"/>
                                    <field name="organism_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="Quejas" name="complaints">
                            <field name="complaint_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="insect"/>
                                    <field name="location"/>
                                    <field name="classification" widget="badge"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.sede – Kanban View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_sede_view_kanban" model="ir.ui.view">
        <field name="name">pest.sede.kanban</field>
        <field name="model">pest.sede</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="city"/>
                <field name="trap_count"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="state" widget="badge"
                                       decoration-success="state == 'active'"
                                        decoration-muted="state == 'inactive'"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <span t-if="record.city.value">
                                    <i class="fa fa-map-marker"/> <field name="city"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span><i class="fa fa-crosshairs"/>
                                        <field name="trap_count"/> Trampas
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.sede – Search View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_sede_view_search" model="ir.ui.view">
        <field name="name">pest.sede.search</field>
        <field name="model">pest.sede</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="city"/>
                <field name="country_id"/>
                <filter string="Activa" name="filter_active"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Inactiva" name="filter_inactive"
                        domain="[('state', '=', 'inactive')]"/>
                <group>
                    <filter string="Ciudad" name="group_city"
                            context="{'group_by': 'city'}"/>
                    <filter string="País" name="group_country"
                            context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.sede – Action
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_sede_action" model="ir.actions.act_window">
        <field name="name">Sedes / Plantas</field>
        <field name="res_model">pest.sede</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="pest_sede_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva sede o planta
            </p>
            <p>Gestione las sedes donde se realiza el control de plagas.</p>
        </field>
    </record>

    <!-- Action for Kanban dashboard -->
    <record id="pest_sede_action_kanban" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">pest.sede</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="pest_sede_view_search"/>
    </record>

</odoo>
