<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pest_trap_movement_wizard_view_form" model="ir.ui.view">
        <field name="name">pest.trap.movement.wizard.form</field>
        <field name="model">pest.trap.movement.wizard</field>
        <field name="arch" type="xml">
            <form string="Mover Trampa">
                <group>
                    <group string="Trampa">
                        <field name="trap_id" string="ID Trampa" readonly="1"/>
                        <field name="trap_type_name"/>
                        <field name="zone_from_id" string="Ubicación Anterior"/>
                    </group>
                    <group string="Destino">
                        <field name="zone_to_id" string="Ubicación Nueva"/>
                        <field name="new_x_pct" invisible="1"/>
                        <field name="new_y_pct" invisible="1"/>
                    </group>
                </group>
                <group>
                    <field name="comment" placeholder="Motivo del movimiento..."/>
                    <field name="user_id"/>
                </group>
                <footer>
                    <button name="action_confirm_move" type="object"
                            string="Confirmar Movimiento" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="pest_trap_movement_wizard_action" model="ir.actions.act_window">
        <field name="name">Mover Trampa</field>
        <field name="res_model">pest.trap.movement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
