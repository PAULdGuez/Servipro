<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.incident – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_incident_view_list" model="ir.ui.view">
        <field name="name">pest.incident.list</field>
        <field name="model">pest.incident</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="date"/>
                <field name="trap_id"/>
                <field name="sede_id"/>
                <field name="plague_type_id"/>
                <field name="incident_type" widget="badge"
                       decoration-success="incident_type == 'captura'"
                       decoration-warning="incident_type == 'hallazgo'"/>
                <field name="insect_type"/>
                <field name="organism_count" sum="Total Organismos"/>
                <field name="inspector"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.incident – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_incident_view_form" model="ir.ui.view">
        <field name="name">pest.incident.form</field>
        <field name="model">pest.incident</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Ubicación">
                            <field name="sede_id"/>
                            <field name="blueprint_id"
                                   domain="[('sede_id', '=', sede_id)]"/>
                            <field name="trap_id"
                                   domain="[('sede_id', '=', sede_id)]"/>
                        </group>
                        <group string="Clasificación">
                            <field name="incident_type" required="1"/>
                            <field name="plague_type_id" required="1"/>
                            <field name="plague_type_custom"/>
                            <field name="insect_type" required="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Detalle">
                            <field name="date"/>
                            <field name="organism_count" required="1"/>
                            <field name="inspector" required="1"/>
                            <field name="inspection_id"/>
                        </group>
                        <group string="Observaciones">
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.incident – Search View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_incident_view_search" model="ir.ui.view">
        <field name="name">pest.incident.search</field>
        <field name="model">pest.incident</field>
        <field name="arch" type="xml">
            <search>
                <field name="trap_id"/>
                <field name="sede_id"/>
                <field name="plague_type_id"/>
                <field name="inspector"/>
                <filter string="Capturas" name="filter_captura"
                        domain="[('incident_type', '=', 'captura')]"/>
                <filter string="Hallazgos" name="filter_hallazgo"
                        domain="[('incident_type', '=', 'hallazgo')]"/>
                <filter string="Voladores" name="filter_volador"
                        domain="[('insect_type', '=', 'volador')]"/>
                <filter string="Rastreros" name="filter_rastrero"
                        domain="[('insect_type', '=', 'rastrero')]"/>
                <group>
                    <filter string="Sede" name="group_sede"
                            context="{'group_by': 'sede_id'}"/>
                    <filter string="Tipo de Plaga" name="group_plague_type"
                            context="{'group_by': 'plague_type_id'}"/>
                    <filter string="Fecha (Mes)" name="group_date_month"
                            context="{'group_by': 'date:month'}"/>
                    <filter string="Tipo de Incidencia" name="group_incident_type"
                            context="{'group_by': 'incident_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.incident – Pivot View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_incident_view_pivot" model="ir.ui.view">
        <field name="name">pest.incident.pivot</field>
        <field name="model">pest.incident</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="plague_type_id" type="row"/>
                <field name="incident_type" type="col"/>
                <field name="organism_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.incident – Graph View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_incident_view_graph" model="ir.ui.view">
        <field name="name">pest.incident.graph</field>
        <field name="model">pest.incident</field>
        <field name="arch" type="xml">
            <graph string="Incidencias" type="bar">
                <field name="date" interval="month" type="col"/>
                <field name="organism_count" type="measure"/>
                <field name="plague_type_id" type="row"/>
            </graph>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.incident – Actions
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_incident_action" model="ir.actions.act_window">
        <field name="name">Todas las Incidencias</field>
        <field name="res_model">pest.incident</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="pest_incident_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registrar una nueva incidencia
            </p>
            <p>Registre capturas y hallazgos de plagas en sus sedes.</p>
        </field>
    </record>

    <record id="pest_incident_action_analysis" model="ir.actions.act_window">
        <field name="name">Análisis de Incidencias</field>
        <field name="res_model">pest.incident</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="pest_incident_view_search"/>
    </record>

</odoo>
