<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.complaint – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_complaint_view_list" model="ir.ui.view">
        <field name="name">pest.complaint.list</field>
        <field name="model">pest.complaint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="sede_id"/>
                <field name="insect"/>
                <field name="location"/>
                <field name="classification" widget="badge"
                       decoration-danger="classification == 'critico'"
                       decoration-warning="classification == 'alto'"
                       decoration-info="classification == 'medio'"
                       decoration-muted="classification == 'bajo'"/>
                <field name="insect_state"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pendiente'"
                       decoration-warning="state == 'en_proceso'"
                       decoration-success="state == 'resuelta'"
                       decoration-muted="state == 'cerrada'"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.complaint – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_complaint_view_form" model="ir.ui.view">
        <field name="name">pest.complaint.form</field>
        <field name="model">pest.complaint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_resolve"
                            type="object"
                            string="Resolver"
                            class="btn-primary"
                             invisible="state not in ('pendiente', 'en_proceso')"/>
                    <button name="action_close"
                            type="object"
                            string="Cerrar"
                            class="btn-secondary"
                            invisible="state != 'resuelta'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pendiente,en_proceso,resuelta,cerrada"/>
                </header>
                <sheet>
                    <group>
                        <group string="Información General">
                            <field name="name"/>
                            <field name="date"/>
                            <field name="sede_id"/>
                        </group>
                        <group string="Detalle de la Queja">
                            <field name="insect"/>
                            <field name="location"/>
                            <field name="classification"/>
                            <field name="insect_state"/>
                        </group>
                    </group>
                    <group string="Adjuntos">
                        <field name="attachment" filename="attachment_filename"/>
                        <field name="attachment_filename" invisible="1"/>
                    </group>
                </sheet>
                <!-- Chatter -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.complaint – Kanban View (grouped by state)
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_complaint_view_kanban" model="ir.ui.view">
        <field name="name">pest.complaint.kanban</field>
        <field name="model">pest.complaint</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="date"/>
                <field name="sede_id"/>
                <field name="insect"/>
                <field name="classification"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="classification" widget="badge"
                                       decoration-danger="classification == 'critico'"
                                       decoration-warning="classification == 'alto'"
                                       decoration-info="classification == 'medio'"
                                       decoration-muted="classification == 'bajo'"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="sede_id"/></div>
                                <div t-if="record.insect.value">
                                    <i class="fa fa-bug" title="Insecto"/> <field name="insect"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <i class="fa fa-calendar" title="Fecha"/>
                                    <field name="date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.complaint – Search View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_complaint_view_search" model="ir.ui.view">
        <field name="name">pest.complaint.search</field>
        <field name="model">pest.complaint</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="sede_id"/>
                <field name="insect"/>
                <filter string="Crítico" name="filter_critico"
                        domain="[('classification', '=', 'critico')]"/>
                <filter string="Alto" name="filter_alto"
                        domain="[('classification', '=', 'alto')]"/>
                <filter string="Medio" name="filter_medio"
                        domain="[('classification', '=', 'medio')]"/>
                <filter string="Bajo" name="filter_bajo"
                        domain="[('classification', '=', 'bajo')]"/>
                <filter string="Pendiente" name="filter_pendiente"
                        domain="[('state', '=', 'pendiente')]"/>
                <filter string="En Proceso" name="filter_en_proceso"
                        domain="[('state', '=', 'en_proceso')]"/>
                <filter string="Resuelta" name="filter_resuelta"
                        domain="[('state', '=', 'resuelta')]"/>
                <filter string="Cerrada" name="filter_cerrada"
                        domain="[('state', '=', 'cerrada')]"/>
                <group>
                    <filter string="Sede" name="group_sede"
                            context="{'group_by': 'sede_id'}"/>
                    <filter string="Clasificación" name="group_classification"
                            context="{'group_by': 'classification'}"/>
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.complaint – Action
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_complaint_action" model="ir.actions.act_window">
        <field name="name">Quejas</field>
        <field name="res_model">pest.complaint</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="pest_complaint_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registrar una nueva queja
            </p>
            <p>Gestione las quejas recibidas sobre plagas en sus sedes.</p>
        </field>
    </record>

</odoo>
