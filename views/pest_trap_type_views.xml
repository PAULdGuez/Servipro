<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.trap.type – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_trap_type_view_list" model="ir.ui.view">
        <field name="name">pest.trap.type.list</field>
        <field name="model">pest.trap.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="icon"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.trap.type – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_trap_type_view_form" model="ir.ui.view">
        <field name="name">pest.trap.type.form</field>
        <field name="model">pest.trap.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="icon"
                                   placeholder="fa-bug"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Descripción"/>
                    <field name="description" placeholder="Descripción del tipo de trampa..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.trap.type – Action
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_trap_type_action" model="ir.actions.act_window">
        <field name="name">Tipos de Trampa</field>
        <field name="res_model">pest.trap.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo tipo de trampa
            </p>
        </field>
    </record>

</odoo>
