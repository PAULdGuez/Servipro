<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.plague.type – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_plague_type_view_list" model="ir.ui.view">
        <field name="name">pest.plague.type.list</field>
        <field name="model">pest.plague.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="category" widget="badge"
                       decoration-info="category == 'volador'"
                       decoration-warning="category == 'rastrero'"
                       decoration-muted="category == 'otro'"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.plague.type – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_plague_type_view_form" model="ir.ui.view">
        <field name="name">pest.plague.type.form</field>
        <field name="model">pest.plague.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="category"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.plague.type – Action
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_plague_type_action" model="ir.actions.act_window">
        <field name="name">Tipos de Plaga</field>
        <field name="res_model">pest.plague.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo tipo de plaga
            </p>
        </field>
    </record>

</odoo>
