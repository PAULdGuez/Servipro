<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pest_incident_import_wizard_view_form" model="ir.ui.view">
        <field name="name">pest.incident.import.wizard.form</field>
        <field name="model">pest.incident.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Incidencias desde Excel">
                <header>
                    <button name="action_download_template" type="object"
                            string="Descargar Plantilla" class="btn-secondary"
                            icon="fa-download"
                            invisible="state != 'draft'"/>
                    <button name="action_upload" type="object"
                            string="Cargar y Previsualizar" class="btn-primary"
                            icon="fa-upload"
                            invisible="state != 'draft'"/>
                    <button name="action_confirm" type="object"
                            string="Confirmar Importación" class="btn-primary"
                            icon="fa-check"
                            invisible="state != 'preview'"
                            confirm="¿Crear las incidencias válidas? Esta acción no se puede deshacer."/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,preview,done"/>
                </header>
                <sheet>
                    <group invisible="state != 'draft'">
                        <group>
                            <field name="blueprint_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="excel_file" filename="excel_filename"
                                   widget="binary" string="Archivo Excel (.xlsx)"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                    </group>
                    <group invisible="state != 'preview'">
                        <div class="d-flex gap-3 mb-2">
                            <span class="badge text-bg-success fs-6">
                                Válidos: <field name="success_count" class="d-inline" readonly="1"/>
                            </span>
                            <span class="badge text-bg-danger fs-6">
                                Errores: <field name="error_count" class="d-inline" readonly="1"/>
                            </span>
                            <span class="badge text-bg-secondary fs-6">
                                Total: <field name="total_count" class="d-inline" readonly="1"/>
                            </span>
                        </div>
                    </group>
                    <field name="preview_line_ids" invisible="state != 'preview'" readonly="1">
                        <list decoration-danger="not is_valid" decoration-success="is_valid">
                            <field name="is_valid" widget="boolean_toggle" readonly="1"/>
                            <field name="trap_name"/>
                            <field name="trap_id"/>
                            <field name="date"/>
                            <field name="plague_type_name"/>
                            <field name="plague_type_id"/>
                            <field name="incident_type"/>
                            <field name="organism_count"/>
                            <field name="notes"/>
                            <field name="error_message"/>
                        </list>
                    </field>
                    <div invisible="state != 'done'" class="alert alert-success text-center">
                        <h4>Importación completada exitosamente</h4>
                        <p>Las incidencias válidas han sido creadas.</p>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="pest_incident_import_wizard_action" model="ir.actions.act_window">
        <field name="name">Importar Incidencias</field>
        <field name="res_model">pest.incident.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
