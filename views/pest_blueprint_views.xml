<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.blueprint – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_blueprint_view_list" model="ir.ui.view">
        <field name="name">pest.blueprint.list</field>
        <field name="model">pest.blueprint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sede_id"/>
                <field name="trap_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.blueprint – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_blueprint_view_form" model="ir.ui.view">
        <field name="name">pest.blueprint.form</field>
        <field name="model">pest.blueprint</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="%(pest_trap_state_wizard_action)d" type="action"
                            string="Registrar Estados" class="btn-secondary"
                            icon="fa-check-square-o"
                            context="{'default_blueprint_id': id}"/>
                    <button name="%(pest_incident_import_wizard_action)d" type="action"
                            string="Importar Excel" class="btn-secondary"
                            icon="fa-file-excel-o"
                            context="{'default_blueprint_id': id}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_traps" icon="fa-crosshairs" style="background-color: #3d3a8c !important; border-color: #3d3a8c !important; color: white !important;">
                            <field name="trap_count" string="Trampas" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_incidents" icon="fa-bug" style="background-color: #3d3a8c !important; border-color: #3d3a8c !important; color: white !important;">
                            <field name="incident_count" string="Incidencias" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_dashboard" icon="fa-bar-chart" style="background-color: #3d3a8c !important; border-color: #3d3a8c !important; color: white !important;">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Gráficas</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="Datos del Plano">
                            <field name="name"/>
                            <field name="sede_id"/>
                            <field name="trap_count"/>
                            <field name="active"/>
                        </group>
                        <group string="Detalle">
                            <field name="description"/>
                            <field name="image" widget="image" string="Subir Plano Original"/>
                        </group>
                    </group>
                    <group string="Umbrales del Heatmap" name="heatmap_config">
                        <div class="mb-2">
                            <strong class="small">Organismos</strong>
                            <div class="d-flex align-items-center gap-4 mt-1">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="heatmap_umbral_bajo" string="Mín"/>
                                    <field name="heatmap_umbral_bajo" nolabel="1" style="width:60px;"/>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <label for="heatmap_umbral_medio" string="Med"/>
                                    <field name="heatmap_umbral_medio" nolabel="1" style="width:60px;"/>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <label for="heatmap_umbral_alto" string="Máx"/>
                                    <field name="heatmap_umbral_alto" nolabel="1" style="width:60px;"/>
                                </div>
                            </div>
                        </div>
                        <div>
                            <strong class="small">Incidencias</strong>
                            <div class="d-flex align-items-center gap-4 mt-1">
                                <div class="d-flex align-items-center gap-2">
                                    <label for="heatmap_inc_umbral_bajo" string="Mín"/>
                                    <field name="heatmap_inc_umbral_bajo" nolabel="1" style="width:60px;"/>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <label for="heatmap_inc_umbral_medio" string="Med"/>
                                    <field name="heatmap_inc_umbral_medio" nolabel="1" style="width:60px;"/>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <label for="heatmap_inc_umbral_alto" string="Máx"/>
                                    <field name="heatmap_inc_umbral_alto" nolabel="1" style="width:60px;"/>
                                </div>
                            </div>
                        </div>
                        <div class="text-muted small mt-1"><i class="fa fa-info-circle"/> Tras guardar, reactive el heatmap para aplicar los nuevos umbrales.</div>
                    </group>
                    <group string="Plano Interactivo">
                        <field name="image_web" widget="blueprint_canvas" nolabel="1" colspan="2"/>
                    </group>

                    <notebook>
                        <page string="Trampas" name="traps">
                            <field name="trap_ids">
                                <list editable="bottom" default_order="name">
                                    <field name="id" string="#" readonly="1"/>
                                    <field name="name"/>
                                     <field name="trap_type_id"/>
                                    <field name="zone_id" string="Ubicación"/>
                                    <field name="coord_x_pct" string="X (%)" optional="hide"/>
                                    <field name="coord_y_pct" string="Y (%)" optional="hide"/>
                                    <field name="coord_x" column_invisible="1"/>
                                    <field name="coord_y" column_invisible="1"/>
                                    <field name="installation_date"/>
                                    <field name="current_state" widget="badge"
                                           decoration-success="current_state == 'funciona'"
                                           decoration-warning="current_state == 'en_reparacion'"
                                           decoration-danger="current_state == 'no_funciona'"
                                           decoration-muted="current_state == 'sin_registro'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Evidencias" name="evidences">
                            <field name="evidence_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="location"/>
                                    <field name="state" widget="badge"
                                           decoration-warning="state == 'pendiente'"
                                           decoration-success="state == 'resuelta'"/>
                                    <field name="supervisor_approval"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.blueprint – Action
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_blueprint_action" model="ir.actions.act_window">
        <field name="name">Planos</field>
        <field name="res_model">pest.blueprint</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo plano de planta
            </p>
            <p>Los planos permiten ubicar trampas visualmente en la sede.</p>
        </field>
    </record>

</odoo>
