<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════
         pest.blueprint – Tree View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_blueprint_view_list" model="ir.ui.view">
        <field name="name">pest.blueprint.list</field>
        <field name="model">pest.blueprint</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="sede_id"/>
                <field name="trap_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.blueprint – Form View
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_blueprint_view_form" model="ir.ui.view">
        <field name="name">pest.blueprint.form</field>
        <field name="model">pest.blueprint</field>
        <field name="arch" type="xml">
            <form class="o_pest_blueprint_form">
                <header>
                    <button name="%(pest_trap_state_wizard_action)d" type="action"
                            string="Registrar Estados" class="btn-secondary"
                            icon="fa-check-square-o"
                            context="{'default_blueprint_id': id}"/>
                    <button name="%(pest_incident_import_wizard_action)d" type="action"
                            string="Importar Excel" class="btn-secondary"
                            icon="fa-file-excel-o"
                            context="{'default_blueprint_id': id}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_traps" icon="fa-crosshairs">
                            <field name="trap_count" string="Trampas" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_view_incidents" icon="fa-bug">
                            <field name="incident_count" string="Incidencias" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group string="Datos del Plano">
                            <field name="name"/>
                            <field name="sede_id"/>
                            <field name="trap_count"/>
                            <field name="active"/>
                        </group>
                        <group string="Detalle">
                            <field name="description"/>
                            <field name="image" widget="image" string="Subir Plano Original"/>
                        </group>
                    </group>
                    <group string="Plano Interactivo">
                        <field name="image_web" widget="blueprint_canvas" nolabel="1" colspan="2"/>
                    </group>

                    <notebook>
                        <page string="Trampas" name="traps">
                            <field name="trap_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                     <field name="trap_type_id"/>
                                    <field name="location"/>
                                    <field name="zone_id"/>
                                    <field name="coord_x_pct" string="X (%)"/>
                                    <field name="coord_y_pct" string="Y (%)"/>
                                    <field name="coord_x" column_invisible="1"/>
                                    <field name="coord_y" column_invisible="1"/>
                                    <field name="installation_date"/>
                                    <field name="current_state" widget="badge"
                                           decoration-success="current_state == 'funciona'"
                                           decoration-warning="current_state == 'en_reparacion'"
                                           decoration-danger="current_state == 'no_funciona'"
                                           decoration-muted="current_state == 'sin_registro'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Evidencias" name="evidences">
                            <field name="evidence_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="location"/>
                                    <field name="state" widget="badge"
                                           decoration-warning="state == 'pendiente'"
                                           decoration-success="state == 'resuelta'"/>
                                    <field name="supervisor_approval"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════
         pest.blueprint – Action
         ════════════════════════════════════════════════════════════════ -->
    <record id="pest_blueprint_action" model="ir.actions.act_window">
        <field name="name">Planos</field>
        <field name="res_model">pest.blueprint</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo plano de planta
            </p>
            <p>Los planos permiten ubicar trampas visualmente en la sede.</p>
        </field>
    </record>

</odoo>
